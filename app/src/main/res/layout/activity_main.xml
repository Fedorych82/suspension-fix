<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="28sp"
        android:paddingBottom="16dp" />

    <TextView
        android:id="@+id/text_bus_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:text="@string/status_unknown"
        android:textSize="16sp"
        android:textIsSelectable="true"
        android:paddingBottom="28dp" />

    <Button
        android:id="@+id/button_lock"
        android:layout_width="320dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:text="@string/btn_lock"
        android:textSize="20sp" />

    <Button
        android:id="@+id/button_unlock"
        android:layout_width="320dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:text="@string/btn_unlock"
        android:textSize="20sp" />

    <Button
        android:id="@+id/button_check"
        android:layout_width="320dp"
        android:layout_height="wrap_content"
        android:text="@string/btn_check"
        android:textSize="18sp" />

    <TextView
        android:id="@+id/text_last_result"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:text=""
        android:textSize="16sp"
        android:textIsSelectable="true"
        android:paddingTop="28dp" />

</LinearLayout>
